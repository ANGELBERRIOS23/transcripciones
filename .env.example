# Gemini API Key (get it from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Password to protect the app (used in the login screen)
SITE_PASSWORD=your_secure_password_here

# Server port (default: 3000)
PORT=3000

# Optional: override the Gemini model (default: gemini-2.5-pro-preview-06-05)
# GEMINI_MODEL=gemini-2.5-pro-preview-06-05
