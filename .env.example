# Gemini API Key (get it from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Password to protect the app (used in the login screen)
SITE_PASSWORD=your_secure_password_here

# Server port (default: 3000)
PORT=3000

# Modelos de IA (se intentan en orden si el anterior está saturado)
# El fallback final siempre es gemini-2.0-flash
GEMINI_MODEL=gemini-3.1-pro-preview
# GEMINI_MODEL_2=gemini-2.5-pro-preview-05-06
# GEMINI_MODEL_3=gemini-2.0-flash

# ── Google Drive (opcional) ───────────────────────────────────────────────────
# Si configuras estas dos variables, el audio original y la transcripción
# se guardarán automáticamente en tu carpeta de Google Drive.
#
# 1. Crea un Service Account en Google Cloud Console
# 2. Habilita la API de Google Drive
# 3. Comparte tu carpeta de Drive con el email del Service Account
# 4. Descarga el JSON del Service Account y pégalo completo aquí:
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# 5. Copia el ID de la carpeta de Drive (está en la URL: drive.google.com/drive/folders/ESTE_ID)
# GOOGLE_DRIVE_FOLDER_ID=1AbCdEfGhIjKlMnOpQrStUvWxYz
